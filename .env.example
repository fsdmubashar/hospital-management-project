# Copy this file to .env and update values as needed.
# Database switch is controlled by HMS_DB_URL only.
# Keep the same app code and swap just the connection string to change DB backend.

# SQLite (default)
HMS_DB_URL=sqlite:///hospital.db

# MySQL / MariaDB (PyMySQL driver)
# HMS_DB_URL=mysql+pymysql://hospital_user:strong_password@mysql:3306/hospital_db

# PostgreSQL (psycopg2 driver)
# HMS_DB_URL=postgresql+psycopg2://hospital_user:strong_password@postgres:5432/hospital_db

# Optional debug profile service credentials
MYSQL_DATABASE=hospital_db
MYSQL_USER=hospital_user
MYSQL_PASSWORD=change_me_mysql_password
MYSQL_ROOT_PASSWORD=change_me_root_password
MYSQL_PORT=3306

POSTGRES_DB=hospital_db
POSTGRES_USER=hospital_user
POSTGRES_PASSWORD=change_me_postgres_password
POSTGRES_PORT=5432
